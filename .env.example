# ─────────────────────────────────────────────────────────────
#  Let's HAB — Backend Environment Variables
#  Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# ── Core / Django ────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api.letshab.com
DJANGO_SETTINGS_MODULE=hab.settings

# Comma-separated origins allowed to call the API / open WS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.letshab.com
CSRF_TRUSTED_ORIGINS=https://app.letshab.com

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://hab:hab@localhost:5432/hab
DB_CONN_MAX_AGE=60

# ── Redis (cache, agent state, Celery broker/result) ─────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Auth / JWT ───────────────────────────────────────────────
JWT_SIGNING_KEY=change-me
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
COOKIE_DOMAIN=.letshab.com
COOKIE_SECURE=True

# ── Realtime service (FastAPI) ───────────────────────────────
REALTIME_HOST=0.0.0.0
REALTIME_PORT=8001
# Public base URL the telephony provider will reach for media streams
REALTIME_PUBLIC_URL=https://realtime.letshab.com

# ── Telephony (Twilio) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_SECRET=

# ── Speech-to-Text (Deepgram) ────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2

# ── Text-to-Speech (Cartesia) ────────────────────────────────
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# ── LLM provider(s) ──────────────────────────────────────────
OPENAI_API_KEY=
# Optional alternates
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ── CRM / Calendar integrations ──────────────────────────────
# Fill only what you use; adapters read these lazily.
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
SERVICETITAN_CLIENT_ID=
SERVICETITAN_CLIENT_SECRET=
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
HOUSECALLPRO_API_KEY=
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ── Billing ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Observability (optional) ─────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
